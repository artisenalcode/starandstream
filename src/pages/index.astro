---
import Layout from '../layouts/Layout.astro';
import Services from '../components/Services';
import ContactForm from '../components/ContactForm';
import { Image } from 'astro:assets';
import logoImage from '../assets/logo.png';
---

<Layout title="Home">
  <main class="bg-white">
    {/* Hero Section */}
    <section class="relative pt-40 pb-24 px-4 flex items-center justify-center min-h-[90vh] overflow-hidden">
      <div class="absolute inset-0 z-0">
        <Image src={import('../assets/images/hero-wyoming.jpg')} alt="Wyoming Landscape" class="w-full h-full object-cover opacity-80" />
        <div class="absolute inset-0 bg-gradient-to-b from-boho-navy/60 via-boho-navy/40 to-white/90"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center mt-10">
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-8 uppercase tracking-widest leading-tight drop-shadow-lg">
          Master the Art of <span class="text-boho-gold">Connection</span>, <span class="text-boho-gold">Credibility</span>, and <span class="text-boho-gold">Code</span>
        </h1>
        <p class="text-xl md:text-2xl text-boho-navy font-medium mb-10 max-w-3xl mx-auto font-sans bg-white/60 p-4 rounded-sm backdrop-blur-sm">
          Star and Stream provides dynamic, human-centric training and engineering solutions to build resilient leaders and incredible teams.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#services" class="inline-block bg-boho-navy text-white px-8 py-4 rounded-sm font-barlow text-lg tracking-wider uppercase hover:bg-boho-gold transition-colors shadow-md">
            Explore Courses & Services
          </a>
          <a href="#contact" class="inline-block bg-white border-2 border-boho-navy text-boho-navy px-8 py-4 rounded-sm font-barlow text-lg tracking-wider uppercase hover:bg-boho-wheat/50 transition-colors shadow-md">
            Contact Us
          </a>
        </div>
      </div>
    </section>

    {/* Philosophy / The Problem */}
    <section class="relative py-32 px-4 overflow-hidden border-y border-boho-wheat/50 shadow-inner">
      <div class="absolute inset-0 z-0">
        <Image src={import('../assets/images/about-wyoming.jpg')} alt="Afton, Wyoming Nature" class="w-full h-full object-cover opacity-40 scale-105" />
        <div class="absolute inset-0 bg-gradient-to-r from-boho-navy/95 to-boho-denim/80"></div>
      </div>
      <div class="relative z-10 max-w-4xl mx-auto text-center text-white">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 uppercase tracking-wider text-white drop-shadow-md">Our Core Philosophy</h2>
        <p class="text-xl md:text-2xl leading-relaxed font-sans max-w-3xl mx-auto text-white drop-shadow-sm font-medium">
          We believe that great work happens when people feel understood, not judged. By breaking down communication barriers and teaching real-world resilience, we help you turn chaotic situations into collaborative wins. It's about staying clear, grounded, and having fun along the way.
        </p>
      </div>
    </section>

    {/* About the Founders */}
    <section id="about" class="py-24 px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-bold text-center text-boho-navy mb-16 uppercase tracking-wider">About the Founders</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div class="bg-white p-8 border border-boho-wheat rounded-sm shadow-sm flex flex-col hover:shadow-md transition-shadow">
            <h3 class="text-3xl font-bold text-boho-gold mb-2 uppercase tracking-wide">Susan Hale</h3>
            <p class="text-sm font-bold text-boho-denim uppercase tracking-widest mb-6 border-b border-boho-wheat pb-4">Escalation Intelligence</p>
            <p class="text-boho-navy/80 leading-relaxed font-sans mb-4 flex-grow">
              Susan draws on her deep background in crisis management and emergency response to teach Escalation Intelligence. More importantly, she brings the warmth and insight of a Licensed Acupuncturist, helping people navigate tricky spaces with ethical clarity, deep focus, and a whole lot of heart.
            </p>
            <a href="/about/susan" class="inline-block mt-4 text-boho-gold font-bold tracking-widest uppercase hover:text-boho-navy transition-colors">Read Susan's Story &rarr;</a>
          </div>

          <div class="bg-white p-8 border border-boho-wheat rounded-sm shadow-sm flex flex-col hover:shadow-md transition-shadow">
            <h3 class="text-3xl font-bold text-boho-gold mb-2 uppercase tracking-wide">Alvin Tolentino</h3>
            <p class="text-sm font-bold text-boho-denim uppercase tracking-widest mb-6 border-b border-boho-wheat pb-4">Fractional VP of Engineering</p>
            <p class="text-boho-navy/80 leading-relaxed font-sans mb-4 flex-grow">
              The technical backbone of Star and Stream, Alvin is a Systems Architect with deep experience navigating fast-paced, complex environments. He approaches technical problem-solving with a highly human-centric lens, teaching others how to build collaborative momentum, reliability, and operational stability with a smile.
            </p>
            <a href="/about/alvin" class="inline-block mt-4 text-boho-gold font-bold tracking-widest uppercase hover:text-boho-navy transition-colors">Read Alvin's Story &rarr;</a>
          </div>
        </div>
      </div>
    </section>

    {/* Services React Component */}
    <Services client:load />

    {/* Why Work With Us */}
    <section class="relative py-32 px-4 overflow-hidden border-y border-boho-wheat/50">
      <div class="absolute inset-0 z-0">
        <Image src={import('../assets/images/afton-valley.jpg')} alt="Star Valley Wyoming" class="w-full h-full object-cover opacity-50" />
        <div class="absolute inset-0 bg-boho-navy/90"></div>
      </div>
      <div class="relative z-10 max-w-6xl mx-auto">
        <h2 class="text-4xl md:text-5xl font-bold text-center mb-16 uppercase tracking-wider text-white drop-shadow-md">Why Work With Us?</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="bg-boho-navy/40 p-8 rounded-sm backdrop-blur-sm border border-boho-wheat/20 hover:border-boho-gold/50 transition-colors">
            <h3 class="text-2xl font-bold text-boho-gold mb-4 uppercase tracking-wide drop-shadow-sm">Real-World Experience</h3>
            <p class="text-white/90 leading-relaxed font-sans text-lg">
              Solutions born from decades of navigating high-level tech environments, emergency response, and community building.
            </p>
          </div>
          <div class="bg-boho-navy/40 p-8 rounded-sm backdrop-blur-sm border border-boho-wheat/20 hover:border-boho-gold/50 transition-colors">
            <h3 class="text-2xl font-bold text-boho-gold mb-4 uppercase tracking-wide drop-shadow-sm">Neutrality & Evidence</h3>
            <p class="text-white/90 leading-relaxed font-sans text-lg">
              We teach you how to redirect conversations toward fair evaluation standards and strip away emotional bias.
            </p>
          </div>
          <div class="bg-boho-navy/40 p-8 rounded-sm backdrop-blur-sm border border-boho-wheat/20 hover:border-boho-gold/50 transition-colors">
            <h3 class="text-2xl font-bold text-boho-gold mb-4 uppercase tracking-wide drop-shadow-sm">Radical Resilience</h3>
            <p class="text-white/90 leading-relaxed font-sans text-lg">
              With backgrounds spanning clinical wellness to executive tech leadership, we guide teams through rapid change with confidence and optimism.
            </p>
          </div>
        </div>
      </div>
    </section>
    
    {/* Contact React Component */}
    <ContactForm client:load />

    {/* Footer */}
    <footer class="bg-boho-navy border-t border-white/10 py-8 text-center text-white/50 font-sans text-sm">
      <p>&copy; {new Date().getFullYear()} Star and Stream. All rights reserved.</p>
    </footer>
  </main>
</Layout>
