---
import Layout from '../layouts/Layout.astro'
---

<Layout title="404 Not Found">
  <section class="mx-auto max-w-4xl px-4 pt-40 pb-20">
    <div class="bg-white p-12 border-4 border-boho-navy rounded-sm shadow-[8px_8px_0px_#C5A059] text-center">
      <p class="font-barlow text-sm tracking-[0.3em] text-boho-gold uppercase mb-4">
        404
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-boho-navy mb-6 uppercase tracking-wider">
        Page Not Found
      </h1>
      <p class="text-lg text-boho-navy/80 max-w-xl mx-auto font-sans mb-10">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block bg-boho-gold border-2 border-boho-navy text-boho-navy px-8 py-4 rounded-sm font-barlow text-lg font-bold tracking-widest uppercase hover:bg-transparent transition-colors shadow-[4px_4px_0px_#0A192F] hover:shadow-none hover:translate-y-1 hover:translate-x-1"
      >
        Return Home
      </a>
    </div>
  </section>
</Layout>
