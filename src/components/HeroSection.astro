---
import { Image } from 'astro:assets'

interface Props {
  title: string
  subtitle: string
}

const { title, subtitle } = Astro.props
---

<section class="relative pt-40 pb-20 px-4 bg-boho-navy overflow-hidden">
  <div class="absolute inset-0 z-0">
    <Image src={import('../assets/images/teutons-afton-wyoming.png')} alt="Wyoming Landscape" class="w-full h-full object-cover opacity-30 grayscale" />
    <div class="absolute inset-0 bg-boho-navy/80 mix-blend-multiply"></div>
  </div>
  <div class="relative z-10 max-w-4xl mx-auto text-center text-white">
    <h1 class="text-5xl md:text-6xl font-bold mb-6 uppercase tracking-widest drop-shadow-md">{title}</h1>
    <p class="text-xl text-white/90 max-w-2xl mx-auto font-sans font-medium drop-shadow-sm">{subtitle}</p>
  </div>
</section>
