# ============================================================
# Environment Variables for starandstream.com
# ============================================================
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real credentials.
# ============================================================

# --- SMTP credentials for contact form email delivery ---
# Nodemailer uses these to send contact form and registration submissions.
# Defaults shown are for Zoho Mail.
# For Zoho, generate an app-specific password: https://mail.zoho.com > Settings > App Passwords

SMTP_HOST="smtp.zoho.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""

# --- Sender and recipient ---
FROM_EMAIL="contact@starandstream.com"
TO_EMAIL="alvin@starandstream.com"
